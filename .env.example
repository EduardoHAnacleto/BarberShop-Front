# Base URL of the BarberShop API (ASP.NET Core 10) the frontend talks to.
# Used by composables/useApi.ts as the Axios baseURL.
NUXT_PUBLIC_API_BASE=http://localhost:8080

# Google Identity Services OAuth Client ID, used for the "Sign in with Google"
# button on /login. Leave blank in development if Google login is not exercised.
NUXT_PUBLIC_GOOGLE_CLIENT_ID=

# Sentry DSN for error monitoring. Leave blank to disable Sentry.
SENTRY_DSN=

# Docker Hub image for the API service (used by docker-compose.yml and docker-compose.staging.yml).
# Override to pin a specific version.
API_IMAGE=eduardohanacleto/barbershop-full:1.0.0

# Shop contact & location — displayed on /about and /book/success.
# Coordinates are used for the Google Maps embed.
NUXT_PUBLIC_SHOP_ADDRESS=1 Sky City, Victoria St W, Auckland CBD 1010, New Zealand
NUXT_PUBLIC_SHOP_PHONE=+64 9 000 0000
NUXT_PUBLIC_SHOP_EMAIL=info@barbershop.com
NUXT_PUBLIC_SHOP_LAT=-36.8682
NUXT_PUBLIC_SHOP_LNG=174.7620

# Google Maps Embed API key (optional).
# Without it, a no-key embed URL is used — suitable for development and placeholder usage.
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=
